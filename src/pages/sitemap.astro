---
import MainLayout from '../layouts/MainLayout.astro';
import { getCollectionWithNumericIds, sortItemsByDateDesc, getAllTags } from '../utils/helpers';
import siteConfig from '../site.config';
import { withBase } from '../utils/helpers';
import Button from '../components/Button.astro';

// 获取所有内容
const posts = (await getCollectionWithNumericIds()).sort(sortItemsByDateDesc);
const tags = getAllTags(posts);

// 站点结构数据（优先级与 astro.config.mjs 保持一致）
const siteStructure = [
  {
    category: '主要页面',
    pages: [
      { title: '首页', url: '/', priority: '1.0', changefreq: 'daily' },
      { title: '博客', url: '/blog', priority: '0.9', changefreq: 'daily' },
      { title: '关于', url: '/about', priority: '0.4', changefreq: 'monthly' },
      { title: '联系', url: '/contact', priority: '0.4', changefreq: 'monthly' },
      { title: '标签索引', url: '/tags', priority: '0.6', changefreq: 'weekly' },
    ],
  },
  {
    category: '博客文章',
    pages: posts.map((post) => ({
      title: post.data.title,
      url: `/blog/${post.id}`,
      priority: '0.7',
      changefreq: 'monthly',
      lastmod: new Date(post.data.pubDate).toLocaleDateString('zh-CN'),
    })),
  },
  {
    category: '标签页面',
    pages: tags.map((tag) => ({
      title: tag.name,
      url: `/tags/${tag.id}`,
      priority: '0.5',
      changefreq: 'weekly',
    })),
  },
];

const totalPages = siteStructure.reduce((total, section) => total + section.pages.length, 0);

// 优先级 → 颜色映射
function getPriorityColor(priority: string) {
  const p = parseFloat(priority);
  if (p >= 0.9) return 'text-green-600 dark:text-green-400';
  if (p >= 0.7) return 'text-amber-600 dark:text-amber-400';
  if (p >= 0.5) return 'text-space-blue dark:text-space-yellow';
  return 'text-gray-500 dark:text-gray-400';
}
---

<MainLayout
  pageTitle={siteConfig.title + ' | 站点地图'}
  pageDescription={'站点地图 - 包含全部' + totalPages + '个页面的完整索引结构'}
>
  <div class="page-content">
    <h1 class="sigmar-ff text-center">站点地图</h1>

    <!-- 站点统计 -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 sm:gap-4 mb-10">
      <div class="stat-card">
        <span class="stat-number sigmar-ff">{totalPages}</span>
        <span class="stat-label kanit-light">总页面数</span>
      </div>
      <div class="stat-card">
        <span class="stat-number sigmar-ff">{posts.length}</span>
        <span class="stat-label kanit-light">博客文章</span>
      </div>
      <div class="stat-card">
        <span class="stat-number sigmar-ff">{tags.length}</span>
        <span class="stat-label kanit-light">标签分类</span>
      </div>
      <div class="stat-card">
        <span class="stat-number sigmar-ff">{siteStructure.length}</span>
        <span class="stat-label kanit-light">内容分区</span>
      </div>
    </div>

    <!-- 站点结构 -->
    <div class="flex flex-col gap-6 sm:gap-8 mb-10">
      {
        siteStructure.map((section) => (
          <section class="sitemap-section">
            <h2 class="section-heading">{section.category}</h2>
            <div class="flex flex-col gap-3">
              {section.pages.map((page) => (
                <a href={withBase(page.url)} class="page-item group">
                  <div class="grow min-w-0">
                    <span class="page-title text-left">{page.title}</span>
                    <div class="flex flex-wrap items-center gap-2 mt-1.5">
                      <span class="meta-badge priority-badge">
                        <span
                          class:list={['inline-block w-1.5 h-1.5 rounded-full mr-1', getPriorityColor(page.priority)]}
                        />
                        优先级 {page.priority}
                      </span>
                      <span class="meta-badge changefreq-badge">{page.changefreq}</span>
                      {page.lastmod && <span class="meta-badge lastmod-badge">{page.lastmod}</span>}
                    </div>
                  </div>
                  <code class="page-url">{withBase(page.url)}</code>
                </a>
              ))}
            </div>
          </section>
        ))
      }
    </div>

    <!-- 说明信息 -->
    <div class="sitemap-info">
      <h3 class="sigmar-ff text-lg sm:text-xl mb-3">关于站点地图</h3>
      <p class="kanit-light text-sm sm:text-base mb-4!">
        本站点地图展示了网站的所有页面结构，帮助搜索引擎更好地理解和索引网站内容。
        每个页面都标注了优先级和更新频率，这些信息有助于搜索引擎优化（SEO）。
      </p>
      <div class="flex flex-wrap gap-3">
        <Button
          href="/sitemap-index.xml"
          target="_blank"
          rel="noopener noreferrer"
          class="space-btn-outlined text-xs! px-4!">
          📄 查看 XML 站点地图
        </Button>
      </div>
    </div>
  </div>
</MainLayout>
