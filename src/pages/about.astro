---
import { Image } from 'astro:assets';
import MainLayout from '../layouts/MainLayout.astro';
import siteConfig from '../site.config';
import { generatePersonSchema } from '../utils/structuredData';
import coverImage from '../assets/images/astronaut-5.png';
---

<MainLayout
  activePage="about"
  pageTitle={siteConfig.title + ' | 关于'}
  pageDescription={siteConfig.about?.text?.substring(0, 160) || siteConfig.description}
>
  <div class="page-content">
    <h1 class="sigmar-ff text-balance">{siteConfig.about?.title}</h1>
    <Image
      width={400}
      height={300}
      loading="lazy"
      layout="constrained"
      class="rounded-4xl mb-8 mx-auto"
      src={coverImage}
      alt="An Astronaut walking on a terrain"
    />
    <p class="kanit-light text-left">
      {siteConfig.about?.text}
    </p>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(generatePersonSchema())}></script>
</MainLayout>
