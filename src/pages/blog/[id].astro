---
import '../../styles/global.css';
import { Image } from 'astro:assets';
import { sortItemsByDateDesc, createSlugFromTitle, withBase, getCollectionWithNumericIds } from '../../utils/helpers';
import { type CollectionEntry, render } from 'astro:content';
import { generateArticleSchema, generateBreadcrumbSchema } from '../../utils/structuredData';
import Button from '../../components/Button.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import MainLayout from '../../layouts/MainLayout.astro';
import ArrowLeft from '../../icons/ArrowLeft.astro';
import ArrowRight from '../../icons/ArrowRight.astro';
import siteConfig from '../../site.config';

export async function getStaticPaths() {
  const posts = (await getCollectionWithNumericIds()).sort(sortItemsByDateDesc);
  const postCount = posts.length;
  return posts.map((post, index) => ({
    params: { id: post.id },
    props: {
      post,
      prevPost: index + 1 !== postCount ? posts[index + 1] : null,
      nextPost: index !== 0 ? posts[index - 1] : null,
    },
  }));
}

type Props = {
  post: CollectionEntry<'blogs'>;
  prevPost: CollectionEntry<'blogs'>;
  nextPost: CollectionEntry<'blogs'>;
};

const { post, prevPost, nextPost } = Astro.props;
const { title, pubDate, author, tags = [], image, description } = post.data;
const { Content } = await render(post);

// 构建当前文章 URL
const articleUrl = new URL(withBase(`/blog/${post.id}`), Astro.site).href;

// 结构化数据
const articleSchema = generateArticleSchema({
  title,
  description,
  url: articleUrl,
  image: image?.url?.src || image?.url?.toString(),
  publishedDate: pubDate,
  authorName: author,
  tags,
});

const breadcrumbSchema = generateBreadcrumbSchema([
  { name: '首页', url: new URL('/', Astro.site).href },
  { name: '博客', url: new URL('/blog', Astro.site).href },
  { name: title, url: articleUrl },
]);
---

<MainLayout
  pageTitle={title + ' | ' + siteConfig.title}
  activePage="blog"
  pageDescription={description}
  pageImage={image?.url?.src || image?.url?.toString()}
  pageCanonicalURL={articleUrl}
  pageType="article"
  pageAuthor={author}
  pagePublishedDate={pubDate}
  pageTags={tags}
>
  <div class="page-content">
    <!-- 面包屑导航 -->
    <Breadcrumbs
      items={[
        { name: '首页', href: withBase('/') },
        { name: '博客', href: withBase('/blog') },
        { name: title, href: withBase(`/blog/${post.id}`) },
      ]}
    />

    <h1 class="sigmar-ff text-center text-balance">{title}</h1>
    <p class="leading-8 text-center kanit-regular text-balance text-xs">
      by 🧑‍🚀 <span class="kanit-bold">{author || 'DescartesZ'}</span> on <span class="kanit-bold">
        {new Date(pubDate).toLocaleDateString('zh-CN')}
      </span>
    </p>
    {image && image.url && <Image class="mb-8 my-6" src={image?.url} alt={image?.alt || title} />}
    <div class="font-light text-left">
      <Content />
    </div>
    <p class="kanit-regular text-center text-balance text-xs">
      标签:
      {
        tags.map((tag) => (
          <Button class="px-4! m-2" href={withBase('/tags/' + createSlugFromTitle(tag))}>
            {tag}
          </Button>
        ))
      }
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 my-8">
      <Button class="back-link" href={withBase('/blog')}>
        <ArrowLeft class="w-5 h-5 fill-current mr-4" /> 返回查看所有文章
      </Button>
      {
        (prevPost || nextPost) && nextPost && (
          <Button class="back-link text-balance" href={withBase('/blog/' + nextPost.id)}>
            上一篇: {nextPost.data.title} <ArrowRight class="w-5 h-5 fill-current ml-4" />
          </Button>
        )
      }
    </div>
  </div>

  <!-- JSON-LD 结构化数据 -->
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)}></script>
</MainLayout>
