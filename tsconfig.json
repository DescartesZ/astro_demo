{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "strictNullChecks": true, // 使用 `base` 模板需要添加
    "allowJs": true // 必需，包含在所有 Astro 模板中
  },
  "include": [
    "src/**/*",
    "env.d.ts",
    ".astro/types.d.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}